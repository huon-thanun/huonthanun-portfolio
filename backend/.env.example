# Server
PORT=5000

# MySQL Database (create this DB using MySQL Workbench or VSCode MySQL extension)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=portfolio_db

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Admin seed account (used by sql/schema.sql seed / seed script)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Email notifications (optional)
# When someone submits the contact form, an email is sent to the address
# set in Dashboard -> Profile -> Email. Leave these blank to disable emails.
#
# Example for Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=youraccount@gmail.com
#   SMTP_PASS=your_16_character_app_password   (NOT your normal Gmail password — see note below)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

