{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:5050/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://localhost:5050/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
