# ==============================
# Dependencies
# ==============================
node_modules/
*/node_modules/

# ==============================
# Environment variables (never commit secrets)
# ==============================
.env
.env.local
.env.*.local
backend/.env

# ==============================
# Build output
# ==============================
frontend/dist/
dist/
dist-ssr/

# ==============================
# Uploaded files (user-generated content, not source code)
# ==============================
backend/uploads/*
!backend/uploads/.gitkeep

# ==============================
# Logs
# ==============================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================
# Editor / OS files
# ==============================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ==============================
# Vite cache
# ==============================
.vite/
*.local

# ==============================
# Misc
# ==============================
*.tgz
.cache/
coverage/
